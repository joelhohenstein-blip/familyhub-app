# ============================================================================
# Family Hub Application - Environment Variables
# ============================================================================
# Copy this file to .env and update with your actual values
# Never commit the actual .env file to version control
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
APP_PORT=3000
PREDEV_DEPLOYMENT_URL=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://family_hub:password@localhost:5432/family_hub
DB_USER=family_hub
DB_PASSWORD=password
DB_NAME=family_hub
DB_PORT=5432
DB_HOST=localhost

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis connection string for caching and real-time features
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ============================================================================
# Authentication (Clerk)
# ============================================================================
# Get these from: https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Real-time Features (Pusher)
# ============================================================================
# Get these from: https://dashboard.pusher.com
PUSHER_APP_ID=123456
PUSHER_KEY=xxxxxxxxxxxxxxxxxxxx
PUSHER_SECRET=xxxxxxxxxxxxxxxxxxxx
PUSHER_CLUSTER=mt1

# ============================================================================
# Video/Audio Communication (Jitsi)
# ============================================================================
# Public Jitsi server or self-hosted instance
JITSI_DOMAIN=meet.jitsi.net
JITSI_ROOM_NAME=family-hub-room

# ============================================================================
# Streaming Services Configuration
# ============================================================================
# API credentials for streaming platforms
PLUTO_API_URL=https://api.pluto.tv
PLUTO_API_KEY=

TUBI_API_URL=https://api.tubitv.com
TUBI_API_KEY=

ROKU_API_URL=https://api.roku.com
ROKU_API_KEY=

FREEVIEW_API_URL=https://api.freeviewplus.com
FREEVIEW_API_KEY=

# ============================================================================
# Weather Service Configuration
# ============================================================================
# OpenWeather API for local weather display
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENWEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Geolocation service (optional)
GEOLOCATION_SERVICE=openweathermap

# ============================================================================
# Payment Processing (Stripe)
# ============================================================================
# Get these from: https://dashboard.stripe.com
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Email Configuration (Resend)
# ============================================================================
# For transactional emails and notifications
# Get your API key from: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: SMTP Configuration for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@familyhub.local

# ============================================================================
# CI/CD & Deployment Secrets (GitHub Actions)
# ============================================================================
# Add these as GitHub Secrets in your repository settings
# GH_TOKEN - GitHub personal access token
# REGISTRY_URL - Container registry URL (if using private registry)
# REGISTRY_USERNAME - Container registry username
# REGISTRY_PASSWORD - Container registry password
# STAGING_DATABASE_URL - Database URL for staging environment
# PRODUCTION_DATABASE_URL - Database URL for production environment
# SLACK_WEBHOOK_URL - For deployment notifications
# DATADOG_API_KEY - For monitoring and logging
# SENTRY_DSN - For error tracking

# ============================================================================
# Development Tools
# ============================================================================
# Debug logging
DEBUG=family-hub:*

# Database UI
ADMINER_PORT=8080
REDIS_COMMANDER_PORT=8081

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_VIDEO_ENABLED=true
FEATURE_MESSAGE_BOARD_ENABLED=true
FEATURE_MEDIA_UPLOAD_ENABLED=true
FEATURE_STREAMING_THEATER_ENABLED=true
FEATURE_WEATHER_WIDGET_ENABLED=true
FEATURE_ADMIN_MODERATION_ENABLED=true

# ============================================================================
# Security
# ============================================================================
# Session configuration
SESSION_SECRET=your-secret-key-min-32-chars-long
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# CORS configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Advanced / Optional Configuration
# ============================================================================

# Content moderation (optional)
MODERATION_API_KEY=
MODERATION_PROVIDER=google  # google, openai, custom

# Analytics (optional)
ANALYTICS_ENABLED=false
GTAG_ID=

# Backup & Storage (optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ============================================================================
# Notes for Developers
# ============================================================================
# 1. NEVER commit the actual .env file to git
# 2. Use .env.example as a template for new developers
# 3. Keep secrets in CI/CD platform (GitHub Secrets) for automation
# 4. Rotate secrets regularly
# 5. Use different credentials for dev/staging/production
# 6. Database backups should be tested monthly
# 7. Always test migrations in staging before production
# ============================================================================
