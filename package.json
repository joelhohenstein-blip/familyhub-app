{
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "clean": "node scripts/clean-restart.js",
    "dev": "node scripts/clean-restart.js && react-router dev --host 0.0.0.0 --port 3000",
    "dev:quick": "react-router dev --host 0.0.0.0 --port 3000",
    "prod": "bun run build && react-router-serve ./build/server/index.js",
    "test": "vitest",
    "tsc": "tsgo",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "start": "react-router-serve ./build/server/index.js",
    "typegen": "react-router typegen",
    "typecheck": "tsgo --noEmit --incremental --tsBuildInfoFile .tsbuildinfo --skipLibCheck",
    "typecheck:full": "react-router typegen && tsgo --noEmit --incremental --tsBuildInfoFile .tsbuildinfo --skipLibCheck",
    "db:push": "npx drizzle-kit push",
    "db:migrate": "tsx app/db/migrate.ts migrate",
    "db:seed": "dotenv -e .env tsx app/db/seed-data.ts",
    "db:wipe": "dotenv -e .env tsx app/db/wipe.ts",
    "db:reset": "npm run db:wipe && npx drizzle-kit push && npm run db:seed",
    "drizzle:generate": "drizzle-kit generate:pg",
    "drizzle:push": "drizzle-kit push:pg",
    "health-check": "bash scripts/health-check.sh",
    "smoke-tests": "bunx scripts/smoke-tests.ts",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "verify-migration": "bash scripts/verify-migration.sh",
    "pre-deploy-checks": "bash scripts/pre-deploy-checks.sh",
    "deploy:check": "npm run pre-deploy-checks && npm run health-check",
    "deploy:verify": "npm run health-check && npm run smoke-tests && npm run verify-migration"
  },
